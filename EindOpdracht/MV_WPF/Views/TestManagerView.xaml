<UserControl x:Class="MV_WPF.Views.TestManagerView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- Generate row -->
		<WrapPanel Grid.Row="0" Margin="0,0,0,10">
			<TextBlock Text="Topic:" VerticalAlignment="Center" Margin="0,0,5,0" />
			<ComboBox Width="180" ItemsSource="{Binding Topics}" SelectedItem="{Binding SelectedTopic}" DisplayMemberPath="Name" />
			<TextBlock Text="  Title:" VerticalAlignment="Center" Margin="10,0,5,0" />
			<TextBox Width="180" Text="{Binding NewTestTitle, UpdateSourceTrigger=PropertyChanged}" />
			<TextBlock Text="  # Q:" VerticalAlignment="Center" Margin="10,0,5,0" />
			<TextBox Width="40" Text="{Binding QuestionCount, UpdateSourceTrigger=PropertyChanged}" />
			<TextBlock Text="  Difficulty(1-3):" VerticalAlignment="Center" Margin="10,0,5,0" />
			<TextBox Width="40" Text="{Binding Difficulty, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
			<TextBlock Text="  Scoring:" VerticalAlignment="Center" Margin="10,0,5,0" />
			<ComboBox Width="170" ItemsSource="{Binding ScoringModes}" SelectedItem="{Binding SelectedScoringMode}" />
			<Button Content="Generate" Margin="10,0,0,0" Padding="10,2" Command="{Binding GenerateCommand}" />
			<Button Content="Refresh"  Margin="5,0,0,0"  Padding="10,2" Command="{Binding RefreshCommand}" />
		</WrapPanel>

		<TextBlock Grid.Row="1" Text="Existing tests (right-click for options):" FontWeight="Bold" Margin="0,0,0,5" />

		<DataGrid Grid.Row="2" ItemsSource="{Binding Tests}" SelectedItem="{Binding SelectedTest}"
			AutoGenerateColumns="False" IsReadOnly="True">
			<DataGrid.ContextMenu>
				<ContextMenu>
					<MenuItem Header="View test contents" Command="{Binding PlacementTarget.DataContext.ViewTestCommand,
						RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
					<MenuItem Header="Delete test" Command="{Binding PlacementTarget.DataContext.DeleteTestCommand,
						RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
				</ContextMenu>
			</DataGrid.ContextMenu>
			<DataGrid.Columns>
				<DataGridTextColumn Header="Id"       Binding="{Binding Id}"       Width="50" />
				<DataGridTextColumn Header="Title"    Binding="{Binding Title}"    Width="*" />
				<DataGridTextColumn Header="Topic"    Binding="{Binding TopicName}" Width="120" />
				<DataGridTextColumn Header="Diff"     Binding="{Binding Difficulty}" Width="50" />
				<DataGridTextColumn Header="Scoring"  Binding="{Binding ScoringStrategy}" Width="120" />
				<DataGridTextColumn Header="Created"  Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="140" />
			</DataGrid.Columns>
		</DataGrid>

		<StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,10,0,0">
			<Button Content="Run Test" Padding="12,3" Background="#2196F3" Foreground="White"
				FontWeight="Bold" Command="{Binding RunTestCommand}" />
			<TextBlock Text="  Export format:" VerticalAlignment="Center" Margin="16,0,5,0" />
			<ComboBox Width="80" ItemsSource="{Binding ExportFormats}" SelectedItem="{Binding SelectedFormat}" />
			<CheckBox Content="Include answers" Margin="8,0,0,0" VerticalAlignment="Center"
				IsChecked="{Binding IncludeAnswers}"
				ToolTip="Append an answer key at the end of the exported file" />
			<Button Content="Export test" Margin="8,0,0,0" Padding="10,2" Command="{Binding ExportCommand}" />
			<TextBlock Text="{Binding Status}" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="DarkSlateGray" />
		</StackPanel>
	</Grid>
</UserControl>
