<UserControl x:Class="MV_WPF.Views.ImportSourceView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<StackPanel Margin="10">

			<!--  Section 1: Topic / question-bank import -->
			<TextBlock Text="Import question bank" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />

			<WrapPanel Margin="0,0,0,8">
				<TextBlock Text="New topic name:" VerticalAlignment="Center" Margin="0,0,5,0" />
				<TextBox Width="200" Text="{Binding NewTopicName, UpdateSourceTrigger=PropertyChanged}" />
				<Button Content="Add topic" Margin="10,0,0,0" Padding="10,2" Command="{Binding AddTopicCommand}" />
				<Button Content="Refresh"   Margin="165,0,0,0"  Padding="10,2" Command="{Binding RefreshCommand}" />
			</WrapPanel>

			<WrapPanel Margin="0,0,0,8">
				<TextBlock Text="Topic:" VerticalAlignment="Center" Margin="0,0,5,0" />
				<ComboBox Width="200" ItemsSource="{Binding Topics}" SelectedItem="{Binding SelectedTopic}" DisplayMemberPath="Name" />
				<TextBlock Text="  Format:" VerticalAlignment="Center" Margin="10,0,5,0" />
				<ComboBox Width="80" ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}" />
				<TextBlock Text="  Difficulty:" VerticalAlignment="Center" Margin="10,0,5,0" />
				<ComboBox Width="55" ItemsSource="{Binding DifficultyOptions}" SelectedItem="{Binding ImportDifficulty}" />
			</WrapPanel>

			<WrapPanel Margin="0,0,0,4">
				<TextBlock Text="File:" VerticalAlignment="Center" Margin="0,0,5,0" />
				<TextBox Width="440" Text="{Binding ImportFilePath, UpdateSourceTrigger=PropertyChanged}" />
				<Button Content="Browse" Margin="5,0,0,0" Padding="10,2" Command="{Binding PickFileCommand}" />
				<Button Content="Import" Margin="10,0,0,0" Padding="15,2" Command="{Binding ImportCommand}" />
			</WrapPanel>

			<Separator Margin="0,16,0,16" />

			<!-- Section 2: Bulk attempt import from file -->
			<TextBlock Text="Bulk import attempts from file" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
			<TextBlock TextWrapping="Wrap" Foreground="DarkSlateGray" Margin="0,0,0,8"
				Text="Select a test and a CSV file where each row is one student attempt. Format: IDGebruiker,Antwoorden (e.g. 42,ABCDA). The OK column shows whether the row was saved — it is false when the UserId is not found in the database." />

			<WrapPanel Margin="0,0,0,8">
				<TextBlock Text="Test:" VerticalAlignment="Center" Margin="0,0,5,0" />
				<ComboBox Width="220" ItemsSource="{Binding BulkTests}" SelectedItem="{Binding BulkSelectedTest}" DisplayMemberPath="Title" />
				<TextBlock Text="  Format:" VerticalAlignment="Center" Margin="10,0,5,0" />
				<ComboBox Width="80" ItemsSource="{Binding BulkFormats}" SelectedItem="{Binding BulkSelectedFormat}" />
			</WrapPanel>

			<WrapPanel Margin="0,0,0,8">
				<TextBlock Text="File:" VerticalAlignment="Center" Margin="0,0,5,0" />
				<TextBox Width="440" Text="{Binding BulkFilePath, UpdateSourceTrigger=PropertyChanged}" />
				<Button Content="Browse file" Margin="5,0,0,0" Padding="10,2" Command="{Binding BulkPickFileCommand}" />
				<Button Content="Import"      Margin="10,0,0,0" Padding="10,2" Command="{Binding BulkImportCommand}" />
			</WrapPanel>

			<!-- Bulk results -->
			<DataGrid ItemsSource="{Binding BulkResults}" AutoGenerateColumns="False"
				IsReadOnly="True" CanUserAddRows="False" MaxHeight="250" Margin="0,0,0,8">
				<DataGrid.Columns>
					<DataGridTextColumn     Header="UserId"  Binding="{Binding UserId}"      Width="70" />
					<DataGridTextColumn     Header="Correct" Binding="{Binding CorrectCount}" Width="60" />
					<DataGridTextColumn     Header="Total"   Binding="{Binding Total}"        Width="50" />
					<DataGridCheckBoxColumn Header="OK"      Binding="{Binding Persisted}"    Width="40"/>
					<DataGridTextColumn     Header="Wrong Q" Binding="{Binding Wrong}"        Width="*" />
				</DataGrid.Columns>
			</DataGrid>

			<TextBlock Text="{Binding Status}" Foreground="DarkSlateGray" />
		</StackPanel>
	</ScrollViewer>
</UserControl>
