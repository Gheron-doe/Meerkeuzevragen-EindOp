<UserControl x:Class="MV_WPF.Views.QuestionEditorView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Grid Margin="10">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- Top toolbar: topic, difficulty filter, text filter, refresh -->
		<WrapPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
			<TextBlock Text="Topic:" VerticalAlignment="Center" Margin="0,0,5,0" />
			<ComboBox Width="200" ItemsSource="{Binding Topics}" SelectedItem="{Binding SelectedTopic}"
				DisplayMemberPath="Name" />
			<TextBlock Text="  Difficulty:" VerticalAlignment="Center" Margin="10,0,5,0" />
			<TextBox Width="40"
				Text="{Binding DifficultyFilter, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
			<TextBlock Text="  Search:" VerticalAlignment="Center" Margin="10,0,5,0" />
			<TextBox Width="200"
				Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
			<Button Content="Refresh" Margin="10,0,0,0" Padding="10,2" Command="{Binding RefreshCommand}" />
		</WrapPanel>

		<!-- Left: existing questions -->
		<Grid Grid.Row="1" Grid.Column="0" Margin="0,0,5,0">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<TextBlock Text="Existing questions (Ctrl/Shift for multi-select):"
				FontWeight="Bold" Margin="0,0,0,5" />

			<!-- Multi-select DataGrid — SelectedItem NOT bound; SelectionChanged wired in code-behind -->
			<DataGrid x:Name="QuestionsGrid" Grid.Row="1"
				ItemsSource="{Binding Questions}"
				AutoGenerateColumns="False" IsReadOnly="True"
				SelectionMode="Extended"
				SelectionChanged="QuestionsGrid_SelectionChanged">
				<DataGrid.Columns>
					<DataGridTextColumn     Header="Id"     Binding="{Binding Id}"             Width="40" />
					<DataGridTextColumn     Header="Text"   Binding="{Binding QuestionText}"    Width="*" />
					<DataGridTextColumn     Header="Diff"   Binding="{Binding DifficultyLevel}" Width="40" />
					<DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}"        Width="50" />
				</DataGrid.Columns>
			</DataGrid>

			<!-- Action buttons row -->
			<WrapPanel Grid.Row="2" Margin="0,5,0,0">
				<Button Content="Activate" Padding="10,2"
					Command="{Binding ActivateCommand}"
					FontWeight="SemiBold"/>
				<Button Content="Deactivate" Margin="5,0,0,0" Padding="10,2"
					Command="{Binding DeactivateCommand}"
					FontWeight="SemiBold"/>
				<Button Content="Delete" Margin="45,0,0,0" Padding="10,2"
					Command="{Binding FlagCommand}"
					FontWeight="SemiBold"/>
			</WrapPanel>
		</Grid>

		<!-- Right: add / edit question -->
		<Grid Grid.Row="1" Grid.Column="1" Margin="5,0,0,0">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<TextBlock Text="{Binding ActionLabel}" FontWeight="Bold" Margin="0,0,0,5" />

			<!-- Column headers for question + feedback -->
			<Grid Grid.Row="1" Margin="0,0,0,2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="Question text:" />
				<TextBlock Grid.Column="1" Text="Question feedback (optional):"
					Margin="5,0,0,0"/>
			</Grid>

			<!-- Question text + feedback side-by-side -->
			<Grid Grid.Row="2" Margin="0,0,0,5">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBox Grid.Column="0"
					Text="{Binding QuestionText, UpdateSourceTrigger=PropertyChanged}"
					AcceptsReturn="True" Height="70" TextWrapping="Wrap"
					VerticalScrollBarVisibility="Auto" Margin="0,0,5,0" Padding="4" />
				<TextBox Grid.Column="1"
					Text="{Binding QuestionFeedback, UpdateSourceTrigger=PropertyChanged}"
					AcceptsReturn="True" Height="70" TextWrapping="Wrap"
					VerticalScrollBarVisibility="Auto" Margin="5,0,0,0" Padding="4"/>
			</Grid>

			<StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,5">
				<TextBlock Text="Difficulty (1-3):" VerticalAlignment="Center" Margin="0,0,5,0" />
				<TextBox Width="40" Text="{Binding Difficulty, UpdateSourceTrigger=PropertyChanged}" />
				<Button Content="+ Answer slot" Margin="10,0,0,0" Padding="6,2"
					Command="{Binding AddAnswerSlotCommand}" />
			</StackPanel>

			<!-- Answer slots with per-answer feedback -->
			<ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
				<ItemsControl ItemsSource="{Binding EditAnswers}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<StackPanel Margin="0,5,0,6">
								<!-- Answer text row -->
								<StackPanel Orientation="Horizontal">
									<CheckBox IsChecked="{Binding IsCorrect}" VerticalAlignment="Center"
										Margin="0,0,5,0" ToolTip="Mark as correct answer" />
									<TextBox Width="260"
										Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
										Padding="3" />
								</StackPanel>
								<!-- Answer feedback (optional) -->
								<StackPanel Orientation="Horizontal">
									<TextBlock Text="Feedback:" VerticalAlignment="Center"
										FontSize="11" Margin="24,2,5,0" />
									<TextBox Width="220"
										Text="{Binding Feedback, UpdateSourceTrigger=PropertyChanged}"
										Padding="3" FontSize="11" />
								</StackPanel>
							</StackPanel>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>

			<StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,5,0,0">
				<Button Content="{Binding ActionLabel}" Padding="10,2"
					Command="{Binding SaveQuestionCommand}" />
				<Button Content="Clear" Margin="8,0,0,0" Padding="10,2"
					Command="{Binding ClearCommand}" />
			</StackPanel>
		</Grid>

		<TextBlock Grid.Row="2" Grid.ColumnSpan="2"
			Text="{Binding Status}" Margin="0,10,0,0" Foreground="DarkSlateGray" />
	</Grid>
</UserControl>
