<Window x:Class="MV_WPF.Views.TestResultWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Test Results" Height="680" Width="800"
	WindowStartupLocation="CenterScreen">

	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis" />

		<!-- Answer highlight: IsUserPick=blue, IsCorrect=green (green wins) -->
		<Style x:Key="AnswerBorderStyle" TargetType="Border">
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="BorderBrush"     Value="Transparent" />
			<Setter Property="Background"      Value="Transparent" />
			<Setter Property="Padding"         Value="6,3" />
			<Setter Property="Margin"          Value="0,2" />
			<Style.Triggers>
				<DataTrigger Binding="{Binding IsUserPick}" Value="True">
					<Setter Property="Background"  Value="#CCE0F5" />
					<Setter Property="BorderBrush" Value="#1565C0" />
				</DataTrigger>
				<DataTrigger Binding="{Binding IsCorrect}" Value="True">
					<Setter Property="Background"  Value="#CCE8CC" />
					<Setter Property="BorderBrush" Value="#2E7D32" />
				</DataTrigger>
			</Style.Triggers>
		</Style>
	</Window.Resources>

	<Grid Margin="16">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- Score row -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
			<TextBlock Text="Score: " FontSize="18" FontWeight="Bold" />
			<TextBlock x:Name="ScoreText" FontSize="18" FontWeight="Bold" Foreground="DarkGreen" />
		</StackPanel>

		<!-- Grader feedback -->
		<StackPanel Grid.Row="1" Margin="0,0,0,10">
			<TextBlock Text="Feedback from grader:" FontWeight="Bold" />
			<TextBlock x:Name="FeedbackText" TextWrapping="Wrap"
				Foreground="DarkSlateGray" Margin="0,4,0,0" />
		</StackPanel>

		<!-- Legend + section header -->
		<StackPanel Grid.Row="2" Margin="0,0,0,6">
			<StackPanel Orientation="Horizontal">
				<Border Width="14" Height="14" Background="#CCE8CC" BorderBrush="#2E7D32" BorderThickness="1"
					VerticalAlignment="Center" Margin="0,0,4,0" />
				<TextBlock Text="Correct answer" Margin="0,0,12,0" VerticalAlignment="Center" />
				<Border Width="14" Height="14" Background="#CCE0F5" BorderBrush="#1565C0" BorderThickness="1"
					VerticalAlignment="Center" Margin="0,0,4,0" />
				<TextBlock Text="Your answer" VerticalAlignment="Center" />
			</StackPanel>
			<TextBlock x:Name="SectionHeader" FontWeight="Bold" Margin="0,8,0,0" />
		</StackPanel>

		<!-- Wrong / unanswered questions -->
		<ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
			<ItemsControl x:Name="ReviewList">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
							Margin="0,0,0,12" Padding="0,0,0,10">
							<StackPanel>
								<!-- Question header -->
								<StackPanel Orientation="Horizontal" Margin="0,0,0,4">
									<TextBlock FontWeight="Bold">
										<Run Text="Q" /><Run Text="{Binding Order}" /><Run Text=". " />
									</TextBlock>
									<TextBlock Text="{Binding QuestionText}"
										TextWrapping="Wrap" MaxWidth="640" />
								</StackPanel>

								<!-- Skipped badge -->
								<TextBlock Text="(skipped — no answer given)" Foreground="Gray" FontStyle="Italic"
									Visibility="{Binding IsSkipped, Converter={StaticResource BoolToVis}}"
									Margin="20,0,0,0" />

								<!-- Answer options -->
								<ItemsControl ItemsSource="{Binding Options}" Margin="20,0,0,0">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<StackPanel>
												<Border Style="{StaticResource AnswerBorderStyle}">
													<StackPanel Orientation="Horizontal">
														<TextBlock Width="20" FontWeight="SemiBold">
															<Run Text="{Binding Label}" /><Run Text=". " />
														</TextBlock>
														<TextBlock Text="{Binding AnswerText}"
															TextWrapping="Wrap" MaxWidth="580" />
														<TextBlock Text="  ✓" Foreground="#2E7D32" FontWeight="Bold"
															Visibility="{Binding IsCorrect, Converter={StaticResource BoolToVis}}" />
														<TextBlock Text="  ← your answer" Foreground="#1565C0"
															FontStyle="Italic"
															Visibility="{Binding IsUserPick, Converter={StaticResource BoolToVis}}" />
													</StackPanel>
												</Border>
												<!-- Per-answer feedback -->
												<TextBlock Margin="26,0,0,2" FontSize="11" FontStyle="Italic"
													Foreground="#555555" TextWrapping="Wrap" MaxWidth="580">
													<TextBlock.Style>
														<Style TargetType="TextBlock">
															<Setter Property="Visibility" Value="Visible" />
															<Style.Triggers>
																<DataTrigger Binding="{Binding Feedback}" Value="{x:Null}">
																	<Setter Property="Visibility" Value="Collapsed" />
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</TextBlock.Style>
													<Run Text="→ " /><Run Text="{Binding Feedback}" />
												</TextBlock>
											</StackPanel>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>

								<!-- Question-level feedback blocks -->
								<StackPanel Margin="20,6,0,0">
									<TextBlock TextWrapping="Wrap" MaxWidth="660" Margin="0,2,0,0"
										FontSize="11" FontStyle="Italic" Foreground="#444">
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Visibility" Value="Visible" />
												<Style.Triggers>
													<DataTrigger Binding="{Binding QuestionFeedbackText}" Value="{x:Null}">
														<Setter Property="Visibility" Value="Collapsed" />
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
										<Run FontWeight="SemiBold" Text="Hint: " />
										<Run Text="{Binding QuestionFeedbackText}" />
									</TextBlock>
									<TextBlock TextWrapping="Wrap" MaxWidth="660" Margin="0,2,0,0"
										FontSize="11" FontStyle="Italic" Foreground="#1565C0">
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Visibility" Value="Visible" />
												<Style.Triggers>
													<DataTrigger Binding="{Binding SelectedAnswerFeedback}" Value="{x:Null}">
														<Setter Property="Visibility" Value="Collapsed" />
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
										<Run FontWeight="SemiBold" Text="Your choice: " />
										<Run Text="{Binding SelectedAnswerFeedback}" />
									</TextBlock>
									<TextBlock TextWrapping="Wrap" MaxWidth="660" Margin="0,2,0,0"
										FontSize="11" FontStyle="Italic" Foreground="#2E7D32">
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Visibility" Value="Visible" />
												<Style.Triggers>
													<DataTrigger Binding="{Binding CorrectAnswerFeedback}" Value="{x:Null}">
														<Setter Property="Visibility" Value="Collapsed" />
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
										<Run FontWeight="SemiBold" Text="Correct answer: " />
										<Run Text="{Binding CorrectAnswerFeedback}" />
									</TextBlock>
								</StackPanel>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</Window>
