<Window x:Class="MV_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MV_WPF"
        mc:Ignorable="d"
        Title="Meerkeuzevragen" Height="720" Width="1100">
    <TabControl>
        <TabItem Header="Tests">
            <ContentControl Content="{Binding TestManager}" />
        </TabItem>
        <TabItem Header="Questions">
            <ContentControl Content="{Binding QuestionEditor}" />
        </TabItem>
        <TabItem Header="Grading">
            <ContentControl Content="{Binding Grading}" />
        </TabItem>
        <TabItem Header="Import source">
            <ContentControl Content="{Binding ImportSource}" />
        </TabItem>
    </TabControl>
</Window>
