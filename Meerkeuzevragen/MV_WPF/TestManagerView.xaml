<UserControl x:Class="MV_WPF.TestManagerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Topics:" VerticalAlignment="Center" Margin="0,0,5,0" />

            <ComboBox x:Name="TopicsCombo" Width="200" Height="26" >
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" 
                                  Tag="{Binding Id}"
                                  Checked="OnTopicChecked"
                                  Unchecked="OnTopicUnchecked" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="  Title:" VerticalAlignment="Center" Margin="10,0,5,0" />
            <TextBox x:Name="TitleBox" Width="180" />

            <TextBlock Text="  Count:" VerticalAlignment="Center" Margin="10,0,5,0" />
            <TextBox x:Name="CountBox" Width="40" Text="10" />

            <TextBlock Text="  #L1:" VerticalAlignment="Center" Margin="10,0,5,0" />
            <TextBox x:Name="Diff1Box" Width="40" />
            <TextBlock Text="  #L2:" VerticalAlignment="Center" Margin="10,0,5,0" />
            <TextBox x:Name="Diff2Box" Width="40" />
            <TextBlock Text="  #L3:" VerticalAlignment="Center" Margin="10,0,5,0" />
            <TextBox x:Name="Diff3Box" Width="40" />

            <Button Content="Generate" Margin="10,0,0,0" Padding="10,2" Click="OnGenerate" />
            <Button Content="Refresh"  Margin="5,0,0,0"  Padding="10,2" Click="OnRefresh" />
        </WrapPanel>

        <TextBlock Grid.Row="1" Text="Existing tests (right-click for options):"
            FontWeight="Bold" Margin="0,0,0,5" />

        <DataGrid x:Name="TestsGrid" Grid.Row="2"
            AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="View test content" Click="OnViewTest" />
                    <MenuItem Header="Delete test"       Click="OnDeleteTest" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"         Binding="{Binding Id}" Width="50" />
                <DataGridTextColumn Header="Title"      Binding="{Binding Title}" Width="*" />
                <DataGridTextColumn Header="Topics"     Binding="{Binding TopicsString}" Width="160" />
                <DataGridTextColumn Header="Difficulty" Binding="{Binding DifficultiesString}" Width="80" />
                <DataGridTextColumn Header="Created"    Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,10,0,0">
            <Button Content="Run test" Padding="12,3" Background="#2196F3"
                Foreground="White" FontWeight="Bold" Click="OnRunTest" />
            <TextBlock Text="  Export as:" VerticalAlignment="Center" Margin="16,0,5,0" />
            <ComboBox x:Name="FormatCombo" Width="80" />
            <CheckBox x:Name="IncludeAnswersCheck" Content="Include answers"
                Margin="8,0,0,0" VerticalAlignment="Center" />
            <Button Content="Export" Margin="8,0,0,0" Padding="10,2" Click="OnExport" />
            <TextBlock x:Name="StatusText" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="DarkSlateGray" />
        </StackPanel>
    </Grid>
</UserControl>