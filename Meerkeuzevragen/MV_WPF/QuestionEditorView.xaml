<UserControl x:Class="MV_WPF.QuestionEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
            <TextBlock Text="Topics:" VerticalAlignment="Center" Margin="0,0,5,0" />
            <ComboBox x:Name="FilterTopicsCombo" Width="180" Height="26" />

            <TextBlock Text="  Difficulty:" VerticalAlignment="Center" Margin="10,0,5,0" />
            <ComboBox x:Name="FilterDiffCombo" Width="120" Height="26" />

            <TextBlock Text="  Search:" VerticalAlignment="Center" Margin="10,0,5,0" />
            <TextBox x:Name="FilterTextBox" Width="180" TextChanged="OnFilterTextChanged" />
            <Button Content="Refresh" Margin="10,0,0,0" Padding="10,2" Click="OnRefresh" />
        </WrapPanel>

        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,5,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Existing questions (Ctrl/Shift for multiple):" FontWeight="Bold" Margin="0,0,0,5" />

            <DataGrid x:Name="QuestionsGrid" Grid.Row="1"
                AutoGenerateColumns="False" IsReadOnly="True"
                SelectionMode="Extended"
                SelectionChanged="OnQuestionSelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn     Header="Id"         Binding="{Binding Id}" Width="40" />
                    <DataGridTextColumn     Header="Text"       Binding="{Binding QuestionText}" Width="*" />
                    <DataGridTextColumn     Header="Difficulty" Binding="{Binding DifficultyLevel}" Width="70" />
                    <DataGridCheckBoxColumn Header="Active"     Binding="{Binding IsActive}" Width="55" />
                </DataGrid.Columns>
            </DataGrid>

            <WrapPanel Grid.Row="2" Margin="0,5,0,0">
                <Button Content="Activate"   Padding="10,2" Click="OnActivate" FontWeight="SemiBold" />
                <Button Content="Deactivate" Padding="10,2" Margin="5,0,0,0"  Click="OnDeactivate" FontWeight="SemiBold" />
                <Button Content="Delete"     Padding="10,2" Margin="45,0,0,0" Click="OnDelete" FontWeight="SemiBold" />
            </WrapPanel>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="1" Margin="5,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="ActionLabel" FontWeight="Bold" Margin="0,0,0,5" Text="Add question" />

            <Grid Grid.Row="1" Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Question text:" />
                <TextBlock Grid.Column="1" Text="Question feedback (optional):" Margin="5,0,0,0" />
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="QuestionTextBox" Grid.Column="0" AcceptsReturn="True" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,5,0" Padding="4" />
                <TextBox x:Name="QuestionFeedbackBox" Grid.Column="1" AcceptsReturn="True" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="5,0,0,0" Padding="4" />
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="Difficulty (1-3):" VerticalAlignment="Center" Margin="0,0,5,0" />
                <TextBox x:Name="DifficultyBox" Width="40" Text="1" />
                <Button Content="+ Answer" Margin="10,0,0,0" Padding="6,2" Click="OnAddAnswerSlot" />
            </StackPanel>

            <Expander Grid.Row="4" Header="Topics (multiple allowed):" IsExpanded="True" Margin="0,0,0,5">
                <WrapPanel x:Name="EditorTopicsPanel" MaxHeight="80" />
            </Expander>

            <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="AnswersPanel" />
            </ScrollViewer>

            <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,5,0,0">
                <Button x:Name="SaveBtn" Content="Add question" Padding="10,2" Click="OnSave" />
                <Button Content="Clear" Margin="8,0,0,0" Padding="10,2" Click="OnClear" />
            </StackPanel>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0" Foreground="DarkSlateGray" />
    </Grid>
</UserControl>