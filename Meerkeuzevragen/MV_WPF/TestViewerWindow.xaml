<Window x:Class="MV_WPF.TestViewerWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="View Test" Height="650" Width="800"
	WindowStartupLocation="CenterScreen">
	<Grid Margin="16">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0" x:Name="TestTitleBlock" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

		<CheckBox Grid.Row="1" Content="Highlight correct answers" IsChecked="{Binding ShowCorrect}"
			Margin="0,0,0,10" x:Name="HighlightToggle" Checked="OnToggle" Unchecked="OnToggle"/>

		<ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
			<ItemsControl x:Name="QuestionsPanel">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,6">
							<StackPanel>
								<TextBlock Text="{Binding Header}" FontWeight="Bold" Margin="0,0,0,4"/>
								<TextBlock Text="{Binding QuestionText}" TextWrapping="Wrap" Margin="0,0,0,6"/>
								<ItemsControl ItemsSource="{Binding Answers}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding Label}"
												Foreground="{Binding Color}"
												FontWeight="{Binding Weight}"
												Margin="6,2"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</Window>
