<Window x:Class="MV_WPF.UsernameDialog"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Enter Username" Height="160" Width="360"
	WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
	<StackPanel Margin="20">
		<TextBlock Text="Username:" Margin="0,0,0,6"/>
		<TextBox x:Name="UsernameBox" Width="300" HorizontalAlignment="Left"
			KeyDown="OnKeyDown"/>
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
			<Button Content="Proceed" Width="80" Margin="0,0,8,0" Click="OnProceed"/>
			<Button Content="Cancel"  Width="80" Click="OnCancel"/>
		</StackPanel>
	</StackPanel>
</Window>
