<Window x:Class="MV_WPF.TestRunnerWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Run Test" Height="700" Width="800"
	WindowStartupLocation="CenterScreen">
	<Grid Margin="16">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0" x:Name="TestTitle" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<ItemsControl x:Name="QuestionsPanel">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,6">
							<StackPanel>
								<TextBlock Text="{Binding Header}" FontWeight="Bold" Margin="0,0,0,4"/>
								<TextBlock Text="{Binding QuestionText}" TextWrapping="Wrap" Margin="0,0,0,6"/>
								<ItemsControl ItemsSource="{Binding AnswerOptions}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<RadioButton Content="{Binding Label}" GroupName="{Binding GroupName}"
												IsChecked="{Binding IsSelected, Mode=TwoWay}"
												Margin="4,2"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
			<Button Content="Submit" Width="100" Padding="0,4" Click="OnSubmit"/>
		</StackPanel>
	</Grid>
</Window>
